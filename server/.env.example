# ═══════════════════════════════════════════════════════════════
#  IT Kinderschule — змінні середовища
#  Локально: скопіюйте цей файл у "server/.env" і заповніть значення
#            (copy .env.example .env  у теці server).
#  На хостингу: ці ж ключі додайте в розділі Environment / Variables
#               вашого сервісу (Render, Railway тощо) — файл .env не потрібен.
#  Файл .env НЕ потрапляє в git (див. .gitignore).
# ═══════════════════════════════════════════════════════════════

# Режим роботи: production — на хостингу, інакше можна не вказувати
NODE_ENV=production

# Порт. Локально 3000. На хостингу зазвичай НЕ чіпати —
# платформа сама передає свій PORT.
PORT=3000

# ── Пошта (надсилання заявок) ────────────────────────────────
# Куди приходять нові заявки (ваша адміністративна пошта)
ADMIN_EMAIL=radarix75@gmail.com

# SMTP-акаунт, з якого надсилаються листи.
# Gmail: увімкніть 2FA → створіть «App Password» (16 символів):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ваш.акаунт@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM_NAME=IT Kinderschule

# Чи надсилати батькам автоматичний лист-підтвердження (true/false)
SEND_CONFIRMATION=true

# ── Адмін-панель (/admin) ────────────────────────────────────
ADMIN_LOGIN=admin
# Придумайте надійний пароль (не "admin"!)
ADMIN_PASSWORD=замініть-на-надійний-пароль

# Секрет для підпису токенів входу. Згенеруйте випадковий рядок:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=замініть-на-довгий-випадковий-рядок

# ── Зберігання даних (важливо на хостингу!) ──────────────────
# Заявки, підписники, контент і завантажені фото зберігаються у файлах.
# Щоб вони НЕ зникали після передеплою — підключіть постійний диск
# і вкажіть тут шляхи до нього (приклад для змонтованого тому /var/data):
# DATA_DIR=/var/data
# UPLOAD_DIR=/var/data/uploads
